    {
      "name": "文章资源",
      "item": [
        {
          "name": "GET 文章列表（应返回200 + 100条）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns 100 posts', () => pm.expect(pm.response.json().length).to.eql(100));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "https://jsonplaceholder.typicode.com/posts"
          }
        },
        {
          "name": "GET 单个文章（应返回200）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Post ID is 1', () => pm.expect(pm.response.json().id).to.eql(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "https://jsonplaceholder.typicode.com/posts/1"
          }
        },
        {
          "name": "POST 创建文章（应返回201）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has id', () => pm.expect(pm.response.json()).to.have.property('id'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"test title\",\n  \"body\": \"test body content\",\n  \"userId\": 1\n}"
            },
            "url": "https://jsonplaceholder.typicode.com/posts"
          }
        }
      ]
    }
