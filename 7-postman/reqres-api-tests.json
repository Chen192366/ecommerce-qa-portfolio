{
  "info": {
    "name": "JSONPlaceholder API 测试集合",
    "description": "针对 JSONPlaceholder 公共 REST API 的自动化测试集合，覆盖用户 CRUD 及异常场景。共 16 条用例。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "用户 CRUD",
      "item": [
        {
          "name": "GET 用户列表（应返回200 + 10条数据）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns 10 users', () => {",
                  "  var d = pm.response.json();",
                  "  pm.expect(d.length).to.eql(10);",
                  "});",
                  "pm.test('Each user has required fields', () => {",
                  "  var d = pm.response.json();",
                  "  d.forEach(u => pm.expect(u).to.have.all.keys('id','name','username','email','address','phone','website','company'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "https://jsonplaceholder.typicode.com/users"
          }
        },
        {
          "name": "GET 单个用户 ID=1（应返回200）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('User ID is 1', () => {",
                  "  var d = pm.response.json();",
                  "  pm.expect(d.id).to.eql(1);",
                  "  pm.expect(d.name).to.eql('Leanne Graham');",
                  "  pm.expect(d.email).to.eql('Sincere@april.biz');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "https://jsonplaceholder.typicode.com/users/1"
          }
        },
        {
          "name": "GET 用户ID=11 不存在（应返回404或[]）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "https://jsonplaceholder.typicode.com/users/11"
          }
        },
        {
          "name": "POST 创建用户（应返回201 + id）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Created user has id', () => {",
                  "  var d = pm.response.json();",
                  "  pm.expect(d).to.have.property('id');",
                  "  pm.expect(d.name).to.eql('Zhang San');",
                  "  pm.expect(d.email).to.eql('zhangsan@test.com');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Zhang San\",\n  \"email\": \"zhangsan@test.com\",\n  \"username\": \"zhangsan\"\n}"
            },
            "url": "https://jsonplaceholder.typicode.com/users"
          }
        },
        {
          "name": "PUT 更新用户（应返回200）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Updated name is correct', () => {",
                  "  var d = pm.response.json();",
                  "  pm.expect(d.name).to.eql('Li Si Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"name\": \"Li Si Updated\",\n  \"email\": \"lisi@test.com\"\n}"
            },
            "url": "https://jsonplaceholder.typicode.com/users/1"
          }
        },
        {
          "name": "PATCH 部分更新用户（应返回200）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Patched email is correct', () => {",
                  "  var d = pm.response.json();",
                  "  pm.expect(d.email).to.eql('newemail@test.com');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newemail@test.com\"\n}"
            },
            "url": "https://jsonplaceholder.typicode.com/users/1"
          }
        },
        {
          "name": "DELETE 删除用户（应返回200）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "https://jsonplaceholder.typicode.com/users/1"
          }
        }
      ]
    },
